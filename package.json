{
  "name": "dataradar",
  "version": "0.1.3",
  "main": "electron/main.cjs",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "menubar:dev": "electron .",
    "menubar:pack": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir --mac",
    "menubar:dist": "npm run build && electron-builder --mac"
  },
  "dependencies": {
    "d3-geo": "^3.1.1",
    "next": "^15.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "topojson-client": "^3.1.0",
    "world-atlas": "^2.0.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/d3-geo": "^3.1.0",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/topojson-client": "^3.1.5",
    "@types/topojson-specification": "^1.0.5",
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3",
    "electron-builder-notarize": "^1.5.2",
    "eslint": "^9",
    "eslint-config-next": "^15.2.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "build": {
    "appId": "com.datafast.dataradar",
    "productName": "DataRadar",
    "asar": true,
    "files": [
      "app/**/*",
      "lib/**/*",
      "public/**/*",
      ".next/**/*",
      "electron/**/*",
      "next.config.js",
      "postcss.config.mjs",
      "tsconfig.json",
      "package.json"
    ],
    "icon": "electron/assets/icon.icns",
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "electron/entitlements.plist",
      "entitlementsInherit": "electron/entitlements.plist",
      "notarize": {
        "teamId": "2KA972GCY8"
      },
      "extendInfo": {
        "LSUIElement": true
      }
    },
    "dmg": {
      "sign": false
    }
  }
}
